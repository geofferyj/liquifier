# ──────────────────────────────────────────────────────────────
# Liquifier – Environment Configuration (copy to .env)
# ──────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_PASSWORD=change_me_in_production

# NATS
NATS_USER=liquifier
NATS_PASSWORD=change_me_in_production

# JWT (generate: openssl rand -base64 64)
JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_BASE64

# KMS Master Key (generate: openssl rand -hex 32)
MASTER_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# EVM RPC endpoints (comma-separated per chain)
EVM_WS_URLS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY,wss://bsc-mainnet.nodereal.io/ws/v1/YOUR_KEY
EVM_RPC_URLS=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY,https://bsc-mainnet.nodereal.io/v1/YOUR_KEY

# App environment
APP__APPLICATION__ENVIRONMENT=production

# Public base URL used in email links
APP__SMTP__BASE_URL=https://liquifier.penitools.com

# CORS trusted origins
APP__API_GATEWAY__CORS_ALLOWED_ORIGIN=https://liquifier.penitools.com
APP__WEBSOCKET__CORS_ALLOWED_ORIGIN=https://liquifier.penitools.com

# Frontend public endpoints (routed by Caddy)
NEXT_PUBLIC_API_URL=https://liquifier.penitools.com
NEXT_PUBLIC_WS_URL=wss://liquifier.penitools.com
